<view class="page">
  <view class="card">
    <view class="brand">猜盐</view>
    <view class="title">{{ shareTitle }}</view>
    <view class="desc">{{ hint }}</view>

    <view class="actions">
      <button class="btn btn-primary" open-type="share">分享给好友</button>
      <button class="btn btn-ghost" bindtap="goBack">返回</button>
    </view>
  </view>
</view>
